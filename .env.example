# Atlas Lens backend
ATLAS_ENV=production
ATLAS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Required for /api/quotas and /api/investigate. Generate with: openssl rand -hex 32
ATLAS_API_KEY=
ATLAS_DOCS_ENABLED=false
ATLAS_RATE_LIMIT_WINDOW_SECONDS=60
ATLAS_RATE_LIMIT_REQUESTS=30
ATLAS_LIVE_RATE_LIMIT_REQUESTS=10
STEALTHMOLE_ASYNC_POLL_ATTEMPTS=2

# Optional: leave unset to use ../.stealthmole/.env from the repository parent.
# STEALTHMOLE_CONFIG_PATH=/absolute/path/to/.stealthmole/.env
STEALTHMOLE_BASE_URL=https://hackathon.stealthmole.com
STEALTHMOLE_ACCESS_KEY=
STEALTHMOLE_SECRET_KEY=

# Optional LLM provider. Atlas Lens works without this using deterministic fusion.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
